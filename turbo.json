{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "VERCEL", "VERCEL_ENV", "VERCEL_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**", ".next/**"],
      "env": [
        "AI_PROVIDER",
        "OPENROUTER_API_KEY",
        "OPENROUTER_BASE_URL",
        "OPENROUTER_TEXT_MODEL",
        "OPENROUTER_VISION_MODEL",
        "GROQ_API_KEY",
        "GROQ_BASE_URL",
        "GROQ_MODEL",
        "GROQ_TEXT_MODEL",
        "GROQ_VISION_MODEL",
        "ZHIPU_API_KEY",
        "ZHIPU_BASE_URL",
        "ZHIPU_TEXT_MODEL",
        "ZHIPU_VISION_MODEL",
        "GEMINI_API_KEY",
        "GEMINI_MODEL",
        "NVIDIA_API_KEY",
        "NVIDIA_BASE_URL",
        "NVIDIA_TEXT_MODEL",
        "NVIDIA_VISION_MODEL",
        "OPENAI_API_KEY",
        "USDA_API_KEY",
        "REDIS_URL",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "ENCRYPTION_KEY",
        "SENDBLUE_API_KEY",
        "SENDBLUE_API_SECRET",
        "SENDBLUE_FROM_NUMBER",
        "SENDBLUE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_PHONE_NUMBER"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "dev:inspect": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {},
    "test": {},
    "clean": {
      "cache": false
    }
  }
}
