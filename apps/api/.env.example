# Sendblue (iMessage gateway)
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=+1XXXXXXXXXX
SENDBLUE_WEBHOOK_SECRET=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# LLM provider: openrouter | groq | gemini | nvidia | zhipu
# If unset, auto-detected from whichever key below is present
# (openrouter > groq > nvidia > gemini > zhipu).
AI_PROVIDER=openrouter

# OpenRouter (recommended — free models, email/Google signup, no phone/region gate)
# Get a key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Optional: override models (":free" ids change / get rate-limited upstream).
# Default is moonshotai/kimi-k2.6:free for both (multimodal: text+tools+vision).
# OPENROUTER_TEXT_MODEL=moonshotai/kimi-k2.6:free
# OPENROUTER_VISION_MODEL=moonshotai/kimi-k2.6:free

# Groq (free, very fast, email/Google signup). Llama 4 Scout = multimodal.
# Get a key at https://console.groq.com/keys
# GROQ_API_KEY=
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Google Gemini (best vision, but free tier is DISABLED in some regions incl. Egypt)
# Free key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# NVIDIA NIM (free, OpenAI-compatible, but requires phone verification by region)
# Get a key at https://build.nvidia.com
# NVIDIA_API_KEY=
# Optional: override host / models
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_TEXT_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Zhipu GLM (free tier: glm-4-flash for text/tools, glm-4v-flash for vision)
# Get a key at https://open.bigmodel.cn (or https://z.ai for the international host)
# ZHIPU_API_KEY=
# Optional: override host for international z.ai accounts
# ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4
# Optional: override default models
# ZHIPU_TEXT_MODEL=glm-4-flash
# ZHIPU_VISION_MODEL=glm-4v-flash

# OpenAI (optional, no longer used by default)
OPENAI_API_KEY=

# USDA FoodData Central (free key: https://fdc.nal.usda.gov/api-key-signup)
USDA_API_KEY=

# Deterministic encryption key for PII (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=
